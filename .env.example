# ============================================================
# PanicGuard AI — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- LLM API Keys (choose one or both) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- LLM Provider Selection ---
# Options: "anthropic" | "openai"
LLM_PROVIDER=anthropic

# --- Model Names ---
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_MODEL=gpt-4o

# --- App Settings ---
APP_ENV=development               # "development" | "production"
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# --- Panic Model Thresholds ---
PANIC_THRESHOLD_LOW=0.30
PANIC_THRESHOLD_MEDIUM=0.60
PANIC_THRESHOLD_HIGH=0.80

# --- Data Cache Settings ---
CACHE_TTL_SECONDS=300            # 5 minutes for live data

# --- Optional: NSE API (future integration) ---
# NSE_API_KEY=your_nse_api_key_here
